<script>

var firstPosition =
<?php echo json_encode($this->positions[0] ?? null); ?>;

var map = L.map('map').setView(
[
    firstPosition.latitude,
    firstPosition.longitude
],
14
);

L.tileLayer(
'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
{
    maxZoom:19
}
).addTo(map);

var markers = {};
var vehicleMeta =
<?php echo json_encode($this->vehicleMeta ?? []); ?>;

<?php foreach ($this->positions as $position): ?>

var popupHtml = '';

var meta =
vehicleMeta[
    <?php echo $position['deviceId']; ?>
] || {};

popupHtml += '<b>'
+ <?php echo json_encode(
    $this->devices[
        array_search(
            $position['deviceId'],
            array_column(
                $this->devices,
                'id'
            )
        )
    ]['name'] ?? ''
); ?>
+ '</b><br>';

if(meta.license_plate)
{
    popupHtml +=
        'Kennzeichen: '
        + meta.license_plate
        + '<br>';
}

if(meta.driver)
{
    popupHtml +=
        'Fahrer: '
        + meta.driver
        + '<br>';
}
var iconName = 'default';

if(meta.marker_icon)
{
    iconName = meta.marker_icon;
}

var vehicleIcon = L.icon({
    iconUrl:
        '/images/gpsportal/markers/'
        + iconName
        + '.svg',

    iconSize:[32,32],
    iconAnchor:[16,16],
    popupAnchor:[0,-16]
});

markers[
    <?php echo $position['deviceId']; ?>
] =
L.marker(
[
    <?php echo $position['latitude']; ?>,
    <?php echo $position['longitude']; ?>
],
{
    icon: vehicleIcon
}
)
.addTo(map)
.bindPopup(
    popupHtml
);

<?php endforeach; ?>

function focusDevice(deviceId)
{
    if(!markers[deviceId])
    {
        return;
    }

    map.setView(
        markers[deviceId].getLatLng(),
        16
    );

    markers[deviceId].openPopup();
}

function updateMap()
{
    fetch('/?option=com_gpsportal&view=api')
    .then(response => response.json())
    .then(data => {

        var onlineCount = 0;
        var vehicleHtml = '';

        data.devices.forEach(function(device){

            var statusText = '🔴 Offline';

            if(device.status === 'online')
            {
                statusText = '🟢 Online';
                onlineCount++;
            }

            vehicleHtml += `
                <div
                    class="vehicle-entry"
                    onclick="focusDevice(${device.id})"
                >
                    <div class="vehicle-name">
                        ${device.name}
                    </div>

                    <div class="vehicle-status">
                        ${statusText}
                    </div>
                </div>
            `;

        });

        document.getElementById(
            'vehicleList'
        ).innerHTML =
            vehicleHtml;

        document.getElementById(
            'deviceCount'
        ).innerText =
            data.devices.length;

        document.getElementById(
            'onlineCount'
        ).innerText =
            onlineCount;

        data.positions.forEach(function(position){

            if(markers[position.deviceId])
            {
                markers[position.deviceId]
                .setLatLng([
                    position.latitude,
                    position.longitude
                ]);
            }

        });

    });
}
updateMap();

setInterval(updateMap, 5000);

</script>
