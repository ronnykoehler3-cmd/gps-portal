        <language tag="es-ES">es-ES/pkg_akeebabackup.sys.ini</language>
        <language tag="pt-PT">pt-PT/pkg_akeebabackup.sys.ini</language>
        <language tag="it-IT">it-IT/pkg_akeebabackup.sys.ini</language>
    </languages>

    <scriptfile>script.akeebabackup.php</scriptfile>

    <updateservers>
        <server type="extension" priority="1" name="Akeeba Backup Core for Joomla!">https://cdn.akeeba.com/updates/pkgakeebabackupcore.xml</server>
